# Secrets and credentials — never commit.
# CLAUDE.md non-negotiable: "Never commit secrets."
*.pem
*.key
*.crt
*.p12
*.pfx
*.kubeconfig
kubeconfig
.env
.env.*
!.env.example
secrets/
**/secrets.yaml
**/secrets.yml
*.token
token
auth-token

# Go build output
/bin/
/dist/
/out/
*.exe
*.test
*.prof
*.out
coverage.out
coverage.txt
coverage.html
cpu.pprof
mem.pprof

# Go workspace
go.work
go.work.sum

# Vendored deps — we prefer modules; flag if someone adds vendor/
vendor/

# Model weights and local model caches — large, out of band of git
*.gguf
*.bin
*.safetensors
models/
.ollama/

# SBOM / provenance artefacts generated by CI; published via releases
*.sbom.json
*.sbom.spdx.json
*.cdx.json
*.intoto.jsonl
provenance.json

# Container / Helm build output
*.tgz
charts/*.tgz
.helm/

# Editor / OS
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Tooling caches
.cache/
.golangci-cache/
.staticcheck/
.air/
tmp/

# Python (legacy/prototype-flask only; no new Python in-tree)
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
